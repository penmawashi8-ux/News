# ===================================================
# 競馬YouTube Shorts自動投稿システム 環境変数設定例
# このファイルを .env にコピーして各値を設定してください
# ===================================================

# Anthropic API Key（AI原稿生成に使用）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# VOICEVOX エンジンURL（デフォルト: http://localhost:50021）
VOICEVOX_URL=http://localhost:50021

# VOICEVOX スピーカーID（3=ずんだもん、デフォルト値）
VOICEVOX_SPEAKER_ID=3

# YouTube API 認証ファイルのパス
YOUTUBE_CLIENT_SECRETS_PATH=client_secrets.json
YOUTUBE_TOKEN_PATH=token.json

# YouTube チャンネルID（任意。指定する場合は設定）
# YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxx

# ログレベル（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# ドライランモード（trueにするとYouTubeへの投稿をスキップ）
DRY_RUN=false
